# =============================================================
#  .gitignore — AI_Final (Image Captioning)
# =============================================================

# -------------------------------------------------------------
# 1. DỮ LIỆU — quá nặng, không đẩy lên GitHub
# -------------------------------------------------------------
data/
self_collect/

# -------------------------------------------------------------
# 2. TRỌNG SỐ MÔ HÌNH
# -------------------------------------------------------------
weights/
*.pth
*.pth.tar
*.pt

# -------------------------------------------------------------
# 3. PYTHON
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
site-packages/

# -------------------------------------------------------------
# 4. MÔI TRƯỜNG ẢO
# -------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# -------------------------------------------------------------
# 5. JUPYTER NOTEBOOK — xóa output trước khi commit
# -------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# -------------------------------------------------------------
# 6. IDE / EDITOR
# -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------------------------------------------
# 7. HỆ ĐIỀU HÀNH
# -------------------------------------------------------------
.DS_Store           # macOS
Thumbs.db           # Windows
desktop.ini

# -------------------------------------------------------------
# 8. LOG & DEBUG
# -------------------------------------------------------------
*.log
logs/
runs/               # TensorBoard logs

# -------------------------------------------------------------
# 9. FILE TẠM / CACHE
# -------------------------------------------------------------
*.tmp
*.temp
.cache/
.pytest_cache/
.mypy_cache/

# -------------------------------------------------------------
# GHI CHÚ: Những thứ NÊN đẩy lên
#   ✔ src/          (toàn bộ source code)
#   ✔ configs/      (hyperparameters)
#   ✔ notebooks/    (đã xóa output cell)
#   ✔ main.py, evaluate.py, evaluate_baseline.py
#   ✔ requirements.txt
#   ✔ README.md
# =============================================================
